# Copy this file to .env and fill in your values

# Backend server URL (local development)
VITE_BACKEND_URL=http://localhost:3000

# OpenWeatherMap API key — get a free key at https://openweathermap.org/api
# Required for real-time UV index data
VITE_OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Geocoding API key (geocode.maps.co) — get a free key at https://geocode.maps.co
VITE_GEOCODE_API_KEY=your_geocode_maps_co_api_key_here

# For production deployment, update VITE_BACKEND_URL to your hosted backend URL
# VITE_BACKEND_URL=https://your-backend-domain.com
